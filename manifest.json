{
  "display_information": {
    "name": "awesome-ea"
  },
  "features": {
    "app_home": {
      "home_tab_enabled": true,
      "messages_tab_enabled": true,
      "messages_tab_read_only_enabled": false
    },
    "bot_user": {
      "display_name": "awesome-ea",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/test-rampup",
        "description": "Test: pull recent message history from a channel",
        "usage_hint": "<channel_id>",
        "should_escape": false
      },
      {
        "command": "/test-resolve",
        "description": "Test: fuzzy-match a query against users and channels",
        "usage_hint": "<query>",
        "should_escape": false
      },
      {
        "command": "/test-postmessage",
        "description": "Test: post a message to a channel or user",
        "usage_hint": "<channel_or_user_id> | <text>",
        "should_escape": false
      },
      {
        "command": "/test-setreminder",
        "description": "Test: create a reminder",
        "usage_hint": "<text> | <when>",
        "should_escape": false
      },
      {
        "command": "/test-createcanvas",
        "description": "Test: create a canvas with a list of items",
        "usage_hint": "<channel_id> | <title> <url> | ...",
        "should_escape": false
      },
      {
        "command": "/ea-reset",
        "description": "Demo reset: clear DM history and re-send greeting (DEV_TOOLS only)",
        "usage_hint": "[all]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "redirect_urls": [
      "https://ngrok-free.app/slack/oauth_redirect"
    ],
    "scopes": {
      "user": [
        "search:read",
        "channels:history",
        "channels:read",
        "groups:history",
        "groups:read",
        "im:history",
        "mpim:history",
        "users:read",
        "search:read.public",
        "search:read.private",
        "search:read.mpim",
        "search:read.im",
        "search:read.files",
        "search:read.users",
        "chat:write",
        "canvases:read",
        "canvases:write",
        "users:read.email",
        "reminders:write",
        "files:read"
      ],
      "bot": [
        "app_mentions:read",
        "channels:history",
        "chat:write",
        "chat:write.customize",
        "groups:history",
        "im:history",
        "im:read",
        "im:write",
        "reactions:write",
        "reactions:read",
        "users:read",
        "reminders:write",
        "canvases:read",
        "canvases:write",
        "channels:read",
        "channels:join",
        "groups:read",
        "files:read",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "request_url": "https://ngrok-free.app/slack/events",
      "bot_events": [
        "app_home_opened",
        "app_mention",
        "message.channels",
        "message.groups",
        "message.im"
      ]
    },
    "interactivity": {
      "is_enabled": true,
      "request_url": "https://ngrok-free.app/slack/events"
    },
    "is_mcp_enabled": true,
    "org_deploy_enabled": true,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
